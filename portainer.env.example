# ===========================================
# MAINTENANCE DASHBOARD - PORTAINER ENVIRONMENT
# ===========================================
# Copy these variables to Portainer Stack Environment Variables section
# Customize the values for your deployment

# ===== REQUIRED SETTINGS =====
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-SECURE-SECRET-KEY-IN-PRODUCTION
DB_PASSWORD=your-secure-database-password-here
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# ===== APPLICATION SETTINGS =====
DEBUG=False
DB_NAME=maintenance_dashboard
DB_USER=postgres

# ===== PORT CONFIGURATION =====
WEB_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

# ===== GITHUB REPOSITORY =====
# Update this to your GitHub repository
GITHUB_REPO=your-username/maintenance-dashboard
DOCKER_IMAGE=maintenance_dashboard:latest

# ===== DOMAIN & SSL SETTINGS =====
# Set your domain name
DOMAIN=maintenance.yourdomain.com

# Enable Traefik integration (if you have Traefik running)
TRAEFIK_ENABLE=true
TLS_ENABLE=true
CERT_RESOLVER=letsencrypt

# ===== PERFORMANCE SETTINGS =====
GUNICORN_WORKERS=3
CELERY_LOG_LEVEL=info

# ===========================================
# DEPLOYMENT INSTRUCTIONS:
# ===========================================
# 1. In Portainer, go to Stacks → Add Stack
# 2. Name: maintenance-dashboard  
# 3. Repository: https://github.com/your-username/maintenance-dashboard
# 4. Compose path: portainer-stack.yml
# 5. Click "Advanced mode" and copy these variables
# 6. Customize the values above
# 7. Deploy the stack
# 8. Access via Containers to create superuser
# ===========================================